// Village Elder — First Conversation
// Phase: 2 | Context: Village Hub
// The elder gives one of many conflicting stories about Kael's parents.

DialogueSequence(
    id: "village_elder_intro",
    trigger: OnInteract("elder_home_npc"),
    scenes: [
        DialogueLine(
            speaker: "Elder Maren",
            portrait: "elder_maren_neutral",
            text: "Kael. You're awake early. The nightmares again?",
            emotion: Compassion,
            duration: Auto,
            on_complete: None,
        ),
        PlayerChoice(
            options: [
                ("Yes. I keep seeing fire and shadows.", "elder_response_honest"),
                ("I'm fine. Just restless.", "elder_response_dismiss"),
                ("Tell me about my parents.", "elder_response_parents"),
            ],
        ),
        // Branch: Honest
        DialogueLine(
            speaker: "Elder Maren",
            portrait: "elder_maren_sad",
            text: "Dreams are the mind's way of holding onto what it cannot understand. They will pass, child.",
            emotion: Melancholy,
            duration: Auto,
            on_complete: SetFlag("elder_knows_nightmares"),
        ),
        // Branch: Parents
        DialogueLine(
            speaker: "Elder Maren",
            portrait: "elder_maren_mysterious",
            text: "Your parents... they died protecting something important. That is all anyone knows.",
            emotion: Mysterious,
            duration: Auto,
            on_complete: None,
        ),
        DialogueLine(
            speaker: "Elder Maren",
            portrait: "elder_maren_neutral",
            text: "Some truths are heavier than a child should carry. When you're older, perhaps.",
            emotion: Wisdom,
            duration: Auto,
            on_complete: None,
        ),
    ],
)
