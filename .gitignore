# ===========================
# The Last Primordial - .gitignore
# Godot 4.3 + .NET/C# Project
# ===========================

# Godot 4.x build/import cache
.godot/
.import/
export_presets.cfg

# .NET / C# build artifacts
bin/
obj/
*.csproj.nuget.*
*.user
*.suo
.vs/

# Mono/C# (Godot legacy)
.mono/
data_*/
mono_crash_*.json

# NuGet
*.nupkg
packages/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Environment variables
.env
.env.local

# LDtk backup files
*.ldtk.bak

# Audio working files (keep only exported formats)
*.flp
*.als
*.rpp-bak

# Large binary assets (tracked via Git LFS if needed)
# *.png
# *.ogg
# *.wav
