# ===========================
# The Last Primordial - .gitignore
# ===========================

# Rust / Cargo build artifacts
/target/
**/*.rs.bk
*.pdb

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Environment variables
.env
.env.local

# Temporary files created during development
dev_plan.txt
game_lore.txt

# LDtk backup files
*.ldtk.bak

# Audio working files (keep only exported formats)
*.flp
*.als
*.rpp-bak

# Large binary assets (tracked via Git LFS if needed)
# *.png
# *.ogg
# *.wav
